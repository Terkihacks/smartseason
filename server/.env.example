# PostgreSQL connection string
# Replace with your actual database URL
# DATABASE_URL="postgresql://username:password@localhost:5432/smartseason?schema=public"
DATABASE_URL="postgresql://kejalink:ray2026@localhost:5432/smartseason?schema=public"
# JWT signing secret — replace with a long random string in production
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# CORS — the client origin
CLIENT_ORIGIN="http://localhost:5173"

# Cookie
# Set to true in production with HTTPS
COOKIE_SECURE=false
